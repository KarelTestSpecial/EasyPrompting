{
  "manifest_version": 3,
  "name": "Easy Prompting",
  "version": "1.0",
  "description": "A safe scratchpad for AI chat prompts. Draft in an open window, never lose a prompt to a stray Enter or Ctrl+C, then copy it.",
  "icons": {
    "16": "icon/ep_icon16x16.png",
    "48": "icon/ep_icon48x48.png",
    "128": "icon/ep_icon128x128.png"
  },
  "permissions": [
    "windows",
    "storage",
    "system.display"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Easy Prompting",
    "default_icon": {
      "16": "icon/ep_icon16x16.png",
      "48": "icon/ep_icon48x48.png"
    }
  }
}
